
@{
    ViewBag.Title = "Giant's Causeway";
    Layout = "~/Views/Shared/_LayoutPageTours.cshtml";
}

<section class="tour-intro">
    <div class="text-content">
        <h1>Giant's Causeway Tour</h1>
        <h3>Discover the Legendary Giant's Causeway and Northern Ireland’s Natural Wonders</h3>
        <p>
            Step into the world of myth and legend as you visit one of the most unique natural sites in the world: the Giant's Causeway. This UNESCO World Heritage Site is renowned for its striking hexagonal basalt columns, which have fascinated visitors for centuries.
            <br />
            <br />
            Departing from Dublin, your journey will take you through the stunning landscapes of Northern Ireland, where history, folklore, and natural beauty come together in perfect harmony.
        </p>
        <h3>Tour Highlights</h3>
        <p>
            Giant's Causeway: Wander through the extraordinary landscape of 40,000 interlocking basalt columns formed by volcanic activity millions of years ago. Hear the legends surrounding this mystical place, including the tale of the giant Finn McCool.
            <br />
            <br />
            Carrick-a-Rede Rope Bridge: Experience the thrill of crossing the famous Carrick-a-Rede Rope Bridge, suspended 100 feet above the sea. The bridge connects the mainland to a small island, offering incredible views of the surrounding coastline.
            <br />
            <br />
            Dunluce Castle: Visit the dramatic ruins of Dunluce Castle, perched on the edge of a cliff overlooking the Atlantic Ocean. Explore its medieval history and enjoy stunning views of the rugged coastline.
        </p>
    </div>
    <div class="tour-text-video">
        <iframe src="https://youtube.com/embed/-tnd4hfmpj0"
                title="Giant's Causeway Tour"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen>
        </iframe>
    </div>
</section>
<section class="tour-content">
    <div class="tour-details">
        <img id="giants-img" src=@Url.Content("~/Content/Images/Giants_Causeway_img1.jpg") alt="Giant's Causeway" />
        <div class="tour-details-text">
            <h3>What's Included</h3>
            <p>
                Round-trip transportation from Dublin in a comfortable, air-conditioned coach.
                <br />
                Professional and knowledgeable local guide to provide insights and stories about the region.
                <br />
                Free time to explore Dunluce Castle, The Dark Hedges and other scenic stops.
            </p>
            <h3>Key Details</h3>
            <p><strong> Departure Time: Daily at 8:00 AM</strong></p>
            <p><strong>Meeting Point: Dublin City Center (specific location provided upon booking)</strong></p>
            <p><strong>Duration: Approximately 12 hours</strong></p>
            <p><strong>Price: €80 per person (includes transportation and guide services).</strong></p>
            <h3>Additional Information</h3>
            <p>
                This tour is suitable for all ages and fitness levels. Don't forget to bring comfortable walking shoes, a rain jacket (just in case), and a camera to capture the stunning landscapes! Snacks and beverages are welcome, but we’ll also have a stop where you can grab lunch at a traditional Irish café or pub.
            </p>
            <button class="book-now" onclick="window.location.href='@Url.Action("Create", "Bookings")'">Book Now</button>
        </div>
    </div>
</section>

@section Scripts{
    <script>
        const images = ['Giants_Causeway_img1.jpg', 'Giants_Causeway_img2.jpg'];
        const giantsImg = document.getElementById('giants-img');
        function changeImage() { const randomIndex = Math.floor(Math.random() * images.length); giantsImg.src = '@Url.Content("~/Content/images/")' + images[randomIndex]; }
        setInterval(changeImage, 3000);
    </script>
}